{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"declaration": true,
		"emitDeclarationOnly": true,
		"declarationMap": false,
		"rootDir": "src",
		"outDir": "lib/typescript",
		"skipLibCheck": true
	},
	"include": ["src"],
	"exclude": [
		"**/*.typecheck.*",
		"**/*.test.*",
		"**/*.spec.*",
		"**/__tests__/**"
	]
}
